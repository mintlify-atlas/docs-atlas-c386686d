{
  "$schema": "https://mintlify.com/docs.json",
  "name": "RigidUI",
  "theme": "palm",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#1e40af"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/fgrreloaded/rigidui"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fgrreloaded/rigidui"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Components",
            "pages": [
              "components/access-manager",
              "components/content-grid",
              "components/currency-manager",
              "components/draggable-dashboard",
              "components/guided-tour",
              "components/image-loader",
              "components/location-picker",
              "components/smart-search"
            ]
          },
          {
            "group": "Form Components",
            "pages": [
              "components/file-uploader",
              "components/multi-step-form-wrapper",
              "components/password-strength-meter",
              "components/smart-form"
            ]
          },
          {
            "group": "Data Display",
            "pages": [
              "components/file-explorer",
              "components/infinite-scroll",
              "components/notification-center"
            ]
          },
          {
            "group": "Creative Components",
            "pages": [
              "components/data-reveal",
              "components/draggable-canvas",
              "components/text-shift",
              "components/creative-buttons"
            ]
          },
          {
            "group": "Hooks",
            "pages": [
              "hooks/use-location"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Usage Guides",
            "pages": [
              "guides/customization",
              "guides/theming",
              "guides/react-native",
              "guides/typescript"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/contributing",
              "guides/development"
            ]
          }
        ]
      }
    ]
  }
}
