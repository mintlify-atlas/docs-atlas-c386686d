  "publicApiSurface": [
    "AccessManager - Authentication and authorization system",
    "ContentGrid - Flexible grid/list component",
    "CurrencyManager - Multi-currency conversion system",
    "DraggableDashboard - Interactive drag-and-drop dashboard",
    "GuidedTour - Interactive step-by-step walkthroughs",
    "ImageLoader - Advanced image loading with loading states",
    "LocationPicker - Geographic location selection",
    "SmartSearch - Advanced search with filters and history",
    "FileUploader - Drag and drop file upload",
    "MultiStepFormWrapper - Guided step-by-step forms",
    "PasswordStrengthMeter - Visual password strength evaluation",
    "SmartForm - Zod-powered form with TanStack Query",
    "FileExplorer - Hierarchical file system browser",
    "InfiniteScroll - Efficient large dataset loading",
    "NotificationCenter - Notification management system",
    "DataReveal - Animated sensitive content reveal",
    "DraggableCanvas - Physics-based draggable canvas",
    "TextShift - Animated text transitions",
    "CreativeButtons - Animated button components",
    "useLocation - Location-based functionality hook"
  ]
